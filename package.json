{
  "name": "ios-haptics",
  "type": "module",
  "version": "2.0.0",
  "description": "haptic feedback for ios safari",
  "author": "tijnjh",
  "license": "MIT",
  "repository": "tijnjh/ios-haptics",
  "keywords": [
    "haptic",
    "haptics",
    "ios",
    "feedback",
    "haptic-feedback",
    "taptic",
    "safari",
    "vibrate"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.mjs",
      "require": "./dist/react/index.js"
    },
    "./vue": {
      "types": {
        "import": "./dist/vue/index.d.mts",
        "require": "./dist/vue/index.d.ts"
      },
      "import": "./dist/vue/index.mjs",
      "require": "./dist/vue/index.js"
    },
    "./svelte": {
      "types": {
        "import": "./dist/svelte/index.d.mts",
        "require": "./dist/svelte/index.d.ts"
      },
      "svelte": "./dist/svelte/index.mjs",
      "import": "./dist/svelte/index.mjs",
      "require": "./dist/svelte/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup; node scripts/build-svelte.mjs",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "svelte": ">=4",
    "vue": ">=3"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@eslint-react/eslint-plugin": "^2.13.0",
    "@sveltejs/vite-plugin-svelte": "^5",
    "@tsconfig/svelte": "^5.0.8",
    "@types/react": "^19",
    "@vitejs/plugin-vue": "^5",
    "@vue/language-core": "^3.2.6",
    "eslint": "^10.0.3",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-svelte": "^3.15.2",
    "react": "^19",
    "rollup-plugin-svelte": "^7.2.3",
    "svelte": "^5",
    "svelte-eslint-parser": "^1.6.0",
    "svelte-preprocess": "^6.0.3",
    "tsup": "^8.5.1",
    "typescript": "^5",
    "vue": "^3",
    "vue-tsc": "^3.2.6"
  }
}
